      "left_knee":   -0.80,
      "left_ankle_ry": 0.15
    },
    "馬": {
      "right_hip_rx":  0.30,
      "right_hip_ry":  0.20,
      "right_knee":   -0.60,
      "right_ankle_rx": -0.15,
      "right_ankle_ry": 0.10,
      "left_hip_rx":  -0.30,
      "left_hip_ry":   0.20,
      "left_knee":    -0.60,
      "left_ankle_rx":  0.15,
      "left_ankle_ry":  0.10
