{
  "_comment": "記号→DOFオフセット辞書（ラジアン）。humanoid.urdf の実際の関節構造に対応。",
  "_dof_system": {
    "revolute": ["right_elbow", "left_elbow", "right_knee(-π~0)", "left_knee(-π~0)"],
    "spherical": "各関節に _rx(roll), _ry(pitch), _rz(yaw) の3軸 euler 角"
  },
  "_coord": {
    "hip_ry":       "前後方向の脚の振り（正=前方、負=後方）",
    "hip_rx":       "側方の開き（外転、正=外）",
    "shoulder_ry":  "前方への腕の挙上（正=前・上方）",
    "shoulder_rx":  "側方への腕の開き（正=外転）",
    "knee":         "膝屈曲（負値=曲げる）",
    "elbow":        "肘屈曲（正値=曲げる）",
    "chest_rz":     "体幹の左右回旋（正=左回り）",
    "chest_rx":     "体幹の前傾（正=前）"
  },

  "歩型": {
    "中": {
      "right_hip_ry": 0.15,
      "right_knee":  -0.30,
      "right_ankle_ry": 0.10,
      "left_hip_ry":  0.15,
      "left_knee":   -0.30,
      "left_ankle_ry": 0.10
    },
    "虚": {
